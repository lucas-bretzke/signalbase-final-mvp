# SignalBase Final MVP
# Copie este arquivo para .env. Os caminhos abaixo sao para execucao local;
# o docker-compose sobrescreve os caminhos internos dos containers.

NODE_ENV=development
HOST=0.0.0.0
PORT=7001

# Base local da Receita Federal e persistencia operacional em JSON.
# Padrao local: SQLite nacional em modo somente leitura.
RECEITA_SOURCE=sqlite
RECEITA_SQLITE_PATH=D:/cnpj_ativo_final.db
RECEITA_SQLITE_BUSY_TIMEOUT_MS=5000

# Alternativa demo: defina RECEITA_SOURCE=csv. O CSV ficticio versionado permite
# executar o fluxo sem a base nacional. Dados reais devem permanecer fora do Git.
RECEITA_CSV_PATH=./apps/api/data/receita-demo.csv
LEAD_SEARCH_DB_PATH=./data/lead-search-db.json
LEAD_SEARCH_BATCH_SIZE=25

# Arquivo SQLite do host montado como /data/receita/cnpj.db:ro pelo Docker Compose.
RECEITA_SQLITE_HOST_PATH=D:/cnpj_ativo_final.db

# Liga/desliga completamente o cruzamento. Com false, o worker nao e chamado e
# a qualidade "muito alto" permanece visivel, mas bloqueada na interface.
LINKEDIN_ENABLED=true

# Worker mode:
# demo = sem acesso ao LinkedIn; retorna dados ficticios para testar a interface.
# real = usa o navegador Puppeteer com uma sessao persistente do operador.
LINKEDIN_WORKER_MODE=demo

# Worker Puppeteer. No Docker Compose, use http://worker:8010.
WORKER_URL=http://127.0.0.1:8010
WORKER_PORT=8010

# Perfil local guarda apenas a sessao controlada pelo operador. Nunca versione.
LINKEDIN_BROWSER_PROFILE_DIR=./data/linkedin-browser-profile
LINKEDIN_CACHE_PATH=./data/linkedin-browser-cache.json
PUPPETEER_HEADLESS=true
# Opcional quando Chrome/Edge ja esta instalado no host:
# PUPPETEER_EXECUTABLE_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
PUPPETEER_NAVIGATION_TIMEOUT_MS=45000
PUPPETEER_MIN_DELAY_MS=1500
PUPPETEER_MAX_COMPANY_CANDIDATES=3
PUPPETEER_MAX_PEOPLE_SEARCHES=8
PUPPETEER_EXTRACT_PROFILE_CONTACTS=true
PUPPETEER_MAX_CONTACT_PROFILES=3

# Optional CNPJ enrichment via BrasilAPI.
BRASILAPI_ENABLED=false
BRASILAPI_TIMEOUT_MS=9000

# Simple operational guards.
MAX_BATCH_SIZE=200
REQUEST_TIMEOUT_MS=120000
ENRICH_CONCURRENCY=5
WORKER_CONCURRENCY=2
